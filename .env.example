# Copy to .env and adjust for local runs: cp .env.example .env
# Quote values that contain spaces, pipes, or commas with special meaning.

# Service
SERVICE_NAME=multi-model-trust
LOG_LEVEL=INFO

# Citation validation
CITATION_TIMEOUT_SECONDS=5
MAX_CITATION_CONCURRENCY=8
MIN_MODEL_RESPONSES=2
CITATION_USER_AGENT="multi-model-trust/0.1.0 (+https://github.com/tejasvi-mehra/multi-model-trust)"

# Consensus tuning
CONSENSUS_SIMILARITY_THRESHOLD=0.35
CONSENSUS_OPPOSITION_SIMILARITY_THRESHOLD=0.35
CONSENSUS_STOPWORDS="a,an,and,are,for,in,is,of,or,the,to,with"
CONSENSUS_OPPOSING_TERMS="suitable|not suitable,recommended|not recommended,supported|unsupported,safe|unsafe,correct|incorrect,increase|decrease,higher|lower"

# Simulated cross-LLM judge (no real model call; emits sample prompt in response)
CROSS_LLM_JUDGE=false
CROSS_LLM_JUDGE_MODEL_NAME="LLM judge model"
CROSS_LLM_JUDGE_BORDERLINE_LOW=0.75
CROSS_LLM_JUDGE_BORDERLINE_HIGH=0.85

# To see cross_llm_judge in samples/llm_judge_request.json, set:
# CROSS_LLM_JUDGE=true

# Example only — not used by the default mock router
# OPENAI_API_KEY=sk-your-key-here
# OPENAI_MODEL=gpt-4o-mini
